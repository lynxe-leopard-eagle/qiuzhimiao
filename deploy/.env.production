# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://qiuzhimiao:your_secure_db_password@db:5432/qiuzhimiao
DATABASE_SYNC_URL=postgresql+psycopg2://qiuzhimiao:your_secure_db_password@db:5432/qiuzhimiao

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# JWT 安全配置
# ============================================
JWT_SECRET_KEY=please_change_this_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ============================================
# LLM API Keys（至少配置一个启用真实AI）
# ============================================
DEEPSEEK_API_KEY=
DOUBAO_API_KEY=
QWEN_API_KEY=

# ============================================
# 对象存储 MinIO
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_to_secure_password
MINIO_BUCKET=qiuzhimiao
MINIO_SECURE=false

# ============================================
# 应用配置
# ============================================
APP_ENV=production
APP_DEBUG=false
UPLOAD_MAX_SIZE=10485760
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
